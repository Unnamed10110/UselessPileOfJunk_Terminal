<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="UselessTerminal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="Useless Terminal">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:ConnectionId='2' x:Name="SessionPanelColumn" Width="0" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Session Panel Placeholder (Phase 5) -->
        <Grid x:ConnectionId='3' x:Name="SessionPanelHost" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" />

        <!-- Main Content: Tabs + Terminal -->
        <Grid Grid.Column="1">
            <controls:TabView x:ConnectionId='4'
                x:Name="TerminalTabView"
                IsAddTabButtonVisible="True"
                                                                     
                                                                     
                                                                   
                VerticalAlignment="Stretch">
                <controls:TabView.TabStripHeader>
                    <Button x:ConnectionId='5'
                        x:Name="TogglePanelButton"
                                                       
                        ToolTipService.ToolTip="Toggle Sessions (Ctrl+B)"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,8"
                        VerticalAlignment="Center"
                        Margin="4,0,0,0">
                        <FontIcon Glyph="&#xE8A7;" FontSize="16" />
                    </Button>
                </controls:TabView.TabStripHeader>
            </controls:TabView>
        </Grid>
    </Grid>

</Window>

