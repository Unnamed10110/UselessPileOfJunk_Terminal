<ui:FluentWindow
    x:Class="UselessTerminal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:UselessTerminal.Controls"
    Title="Useless Terminal By Unnamed10110"
    Icon="pack://application:,,,/Assets/app.ico"
    Width="1200" Height="800"
    MinWidth="480" MinHeight="360"
    ResizeMode="CanResize"
    WindowStartupLocation="Manual"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="None"
    Background="#000000">

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding TogglePanelCommand}" />
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding NewTabCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title Bar: chrome from TitleBar; centered caption bound to Window.Title (pass-through overlay) -->
        <Grid Grid.Row="0">
            <ui:TitleBar x:Name="MainTitleBar"
                         Title=""
                         ShowMaximize="True" ShowMinimize="True"
                         Background="#000000"
                         Foreground="#ffffff"
                         ButtonsBackground="#000000"
                         ButtonsForeground="#ffffff"
                         Height="16"
                         MinHeight="30"
                         MaxHeight="30"
                         Padding="2,0"
                         FontSize="12" />
            <Grid IsHitTestVisible="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="#ffffff"
                           FontSize="16"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />
            </Grid>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SessionPanelColumn" Width="0" MinWidth="0" MaxWidth="900" />
                <ColumnDefinition x:Name="SessionSplitterColumn" Width="0" MinWidth="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="BrowserSplitterColumn" Width="0" MinWidth="0" />
                <ColumnDefinition x:Name="BrowserPanelColumn" Width="0" MinWidth="0" MaxWidth="1600" />
            </Grid.ColumnDefinitions>

            <!-- Session Panel -->
            <Border Grid.Column="0" Background="#000000" BorderBrush="#333333" BorderThickness="0,0,1,0">
                <local:SessionPanel x:Name="SessionPanel" MinWidth="0" HorizontalAlignment="Stretch" />
            </Border>

            <GridSplitter x:Name="SessionGridSplitter"
                          Grid.Column="1"
                          Width="5" HorizontalAlignment="Stretch"
                          Background="#333333" BorderThickness="0"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          Cursor="SizeWE"
                          DragCompleted="SessionGridSplitter_DragCompleted" />

            <!-- Main Content: Tab Bar + Terminal.
                 Right/bottom margin keeps a WPF-only strip so WebView2 does not cover the window edge
                 (HWND would otherwise steal WM_NCHITTEST and block resizing on that side). -->
            <Grid Grid.Column="2" Margin="0,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Tab Strip -->
                <Border Grid.Row="0" Background="#000000" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="0">
                    <DockPanel>
                        <Button x:Name="TogglePanelButton" DockPanel.Dock="Left"
                                Click="TogglePanelButton_Click"
                                ToolTip="Toggle Sessions (Ctrl+B)"
                                Background="Transparent" BorderThickness="0"
                                Padding="10,6" Margin="4,2" Cursor="Hand"
                                Foreground="#ffffff">
                            <ui:SymbolIcon Symbol="PanelLeft24" FontSize="16" />
                        </Button>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="BrowserToggleButton"
                                    Click="BrowserToggleButton_Click"
                                    ToolTip="Toggle Browser (Ctrl+Shift+B)"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="10,6" Margin="4,2,0,2" Cursor="Hand"
                                    Foreground="#ffffff">
                                <ui:SymbolIcon Symbol="Globe24" FontSize="16" />
                            </Button>
                            <Button x:Name="SettingsButton"
                                    Click="SettingsButton_Click"
                                    ToolTip="Settings (Ctrl+,)"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="10,6" Margin="4,2,0,2" Cursor="Hand"
                                    Foreground="#ffffff">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="16" />
                            </Button>
                            <Button x:Name="NewTabButton"
                                    Click="NewTabButton_Click"
                                    ToolTip="New Tab (Ctrl+T)"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="10,6" Margin="4,2,0,2" Cursor="Hand"
                                    Foreground="#ffffff">
                                <ui:SymbolIcon Symbol="Add24" FontSize="16" />
                            </Button>
                            <Button x:Name="NewTabDropdown"
                                    Click="NewTabDropdown_Click"
                                    ToolTip="Select shell"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="4,6" Margin="0,2,4,2" Cursor="Hand"
                                    Foreground="#ffffff">
                                <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10" />
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ShellMenu" />
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>

                        <TabControl x:Name="TabStrip"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Margin="0"
                                    AllowDrop="True"
                                    PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="TabStrip_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="TabStrip_PreviewMouseLeftButtonUp"
                                    PreviewDragOver="TabStrip_PreviewDragOver"
                                    Drop="TabStrip_Drop"
                                    SelectionChanged="TabStrip_SelectionChanged">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#ffffff" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="10,4" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="FontSize" Value="10" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="TabBorder"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}"
                                                        Margin="1,2" CornerRadius="4"
                                                        BorderThickness="1" BorderBrush="Transparent">
                                                    <DockPanel>
                                                        <Button x:Name="CloseBtn" DockPanel.Dock="Right"
                                                                Click="TabCloseButton_Click"
                                                                Tag="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Padding="4,0" Margin="6,0,0,0" Cursor="Hand"
                                                                Foreground="#888888" FontSize="10"
                                                                Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                                VerticalAlignment="Center" />
                                                        <ContentPresenter ContentSource="Header"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                                    </DockPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Opacity" Value="1" />
                                                        <Setter TargetName="CloseBtn" Property="Foreground" Value="#000000" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="False">
                                                        <Setter TargetName="CloseBtn" Property="Foreground" Value="#888888" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                            <Condition Property="IsSelected" Value="False" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="TabBorder" Property="Opacity" Value="0.75" />
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.ItemContainerStyle>
                        </TabControl>
                    </DockPanel>
                </Border>

                <!-- Terminal Content Area -->
                <Grid x:Name="TerminalHost" Grid.Row="1" Background="#000000" Margin="0,0,0,0" />

                <!-- Status Bar (own row so WebView2 HWND doesn't cover it) -->
                <Border Grid.Row="2" Height="22"
                        Background="#0a0a0a" BorderBrush="#1a1a1a" BorderThickness="0,1,0,0"
                        Padding="10,0">
                    <DockPanel>
                        <TextBlock x:Name="StatusAlive" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   Foreground="#22c55e" FontSize="10.5" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusShell" Foreground="#a1a1aa" FontSize="10.5" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock x:Name="StatusPid" Foreground="#71717a" FontSize="10.5"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock x:Name="StatusCwd" Foreground="#d4d4d8" FontSize="10.5"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       MaxWidth="500" Margin="0,0,12,0" />
                            <TextBlock x:Name="StatusGitBranch" Foreground="#22d3ee" FontSize="10.5"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock x:Name="StatusExitCode" Foreground="#a1a1aa" FontSize="10.5"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Browser Splitter -->
            <GridSplitter x:Name="BrowserGridSplitter"
                          Grid.Column="3"
                          Width="5" HorizontalAlignment="Stretch"
                          Background="#333333" BorderThickness="0"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          Cursor="SizeWE"
                          DragCompleted="BrowserGridSplitter_DragCompleted" />

            <!-- Browser Panel -->
            <Border Grid.Column="4" Background="#0a0a0a" BorderBrush="#333333" BorderThickness="1,0,0,0">
                <local:BrowserPanel x:Name="BrowserPanel" MinWidth="0" HorizontalAlignment="Stretch" />
            </Border>
        </Grid>
    </Grid>

</ui:FluentWindow>
