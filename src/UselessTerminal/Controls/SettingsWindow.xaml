<Window
    x:Class="UselessTerminal.Controls.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="560" Height="660"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#000000"
    Foreground="#ffffff">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel>

                <!-- Font Section -->
                <TextBlock Text="F O N T" FontSize="11" FontWeight="Bold" Foreground="#888888"
                           Margin="0,0,0,10" />

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Family" Width="120" Foreground="#ffffff" VerticalAlignment="Center" />
                    <ComboBox x:Name="FontFamilyBox" IsEditable="True"
                              Background="#000000" Foreground="#ffffff"
                              BorderBrush="#555555" BorderThickness="1" Padding="8,5" />
                </DockPanel>

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Size" Width="120" Foreground="#ffffff" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="FontSizeSlider" Width="200" Minimum="8" Maximum="32"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="FontSizeSlider_ValueChanged"
                                VerticalAlignment="Center" />
                        <TextBlock x:Name="FontSizeLabel" Width="40" Foreground="#ffffff"
                                   VerticalAlignment="Center" TextAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </DockPanel>

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Cursor Style" Width="120" Foreground="#ffffff" VerticalAlignment="Center" />
                    <ComboBox x:Name="CursorStyleBox"
                              Background="#000000" Foreground="#ffffff"
                              BorderBrush="#555555" BorderThickness="1" Padding="8,5">
                        <ComboBoxItem Content="bar" />
                        <ComboBoxItem Content="block" />
                        <ComboBoxItem Content="underline" />
                    </ComboBox>
                </DockPanel>

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Cursor Blink" Width="120" Foreground="#ffffff" VerticalAlignment="Center" />
                    <CheckBox x:Name="CursorBlinkBox" VerticalAlignment="Center" />
                </DockPanel>

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Scrollback" Width="120" Foreground="#ffffff" VerticalAlignment="Center" />
                    <TextBox x:Name="ScrollbackBox" Width="100" Padding="8,5"
                             Background="#000000" Foreground="#ffffff"
                             BorderBrush="#555555" BorderThickness="1" />
                </DockPanel>

                <Border Height="1" Background="#333333" Margin="0,10,0,20" />

                <!-- Background & Foreground -->
                <TextBlock Text="C O L O R S" FontSize="11" FontWeight="Bold" Foreground="#888888"
                           Margin="0,0,0,10" />

                <UniformGrid x:Name="ColorGrid" Columns="2" Margin="0,0,0,10">
                    <!-- Populated in code-behind -->
                </UniformGrid>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="1" Padding="24,12" BorderBrush="#333333" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button Content="Reset Defaults" Click="ResetDefaults_Click" DockPanel.Dock="Left"
                        Padding="16,8" Background="#000000" Foreground="#888888"
                        BorderBrush="#555555" BorderThickness="1" Cursor="Hand" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Cancel_Click" Padding="16,8"
                            Margin="0,0,8,0" Background="#000000" Foreground="#ffffff"
                            BorderBrush="#555555" BorderThickness="1" Cursor="Hand" />
                    <Button Content="Save" Click="Save_Click" Padding="16,8"
                            Background="#ffffff" Foreground="#000000"
                            BorderThickness="0" FontWeight="Bold" Cursor="Hand" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>

</Window>
