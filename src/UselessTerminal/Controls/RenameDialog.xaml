<Window
    x:Class="UselessTerminal.Controls.RenameDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Rename Tab"
    Width="360" SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#000000"
    Foreground="#ffffff">

    <StackPanel Margin="20">
        <TextBox x:Name="NameBox" FontSize="14" Padding="8,6"
                 Background="#000000" Foreground="#ffffff"
                 BorderBrush="#555555" BorderThickness="1"
                 KeyDown="NameBox_KeyDown" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Padding="14,6"
                    Margin="0,0,8,0" Background="#000000" Foreground="#ffffff"
                    BorderBrush="#555555" BorderThickness="1" />
            <Button Content="OK" Click="Ok_Click" Padding="14,6"
                    Background="#ffffff" Foreground="#000000"
                    BorderThickness="0" FontWeight="Bold" />
        </StackPanel>
    </StackPanel>

</Window>
