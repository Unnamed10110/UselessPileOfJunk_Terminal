<UserControl
    x:Class="UselessTerminal.Controls.SessionPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:UselessTerminal.Controls"
    xmlns:conv="clr-namespace:UselessTerminal.Converters"
    MinWidth="0"
    HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <conv:HexColorConverter x:Key="HexColor" />
        <conv:SavedSessionShellIconConverter x:Key="SessionShellIcon" />

        <SolidColorBrush x:Key="SessionPanelBg" Color="#000000" />
        <SolidColorBrush x:Key="SessionTreeWell" Color="#000000" />
        <SolidColorBrush x:Key="SessionDivider" Color="#1f2128" />
        <SolidColorBrush x:Key="SessionTextSecondary" Color="#9ca3af" />
        <SolidColorBrush x:Key="SessionFolderCardBg" Color="#0f1118" />
        <SolidColorBrush x:Key="SessionFolderCardBorder" Color="#232836" />
        <SolidColorBrush x:Key="SessionFolderSelectedBg" Color="#161c28" />
        <SolidColorBrush x:Key="SessionRowHover" Color="#12ffffff" />
        <SolidColorBrush x:Key="SessionMultiSelectRing" Color="#818cf8" />
        <SolidColorBrush x:Key="SessionIndentGuide" Color="#1a2030" />

        <Style x:Key="SessionTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#f4f4f5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel HorizontalAlignment="Stretch">
                            <ContentPresenter x:Name="PART_Header"
                                              HorizontalAlignment="Stretch"
                                              ContentSource="Header"
                                              Margin="0,2" />
                            <Border x:Name="ChildrenBorder" Margin="14,0,0,0"
                                    BorderBrush="{StaticResource SessionIndentGuide}"
                                    BorderThickness="1,0,0,0" Padding="14,0,0,0">
                                <ItemsPresenter x:Name="ItemsHost" />
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ChildrenBorder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ChildrenBorder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:SessionTreeNode}" ItemsSource="{Binding Children}">
            <Grid HorizontalAlignment="Stretch" MinWidth="0" ClipToBounds="True">
                <!-- ═══ Folder card ═══ -->
                <Border MinHeight="44" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        CornerRadius="8" Padding="6,6,10,6" BorderThickness="1"
                        Background="{StaticResource SessionFolderCardBg}"
                        BorderBrush="{StaticResource SessionFolderCardBorder}">
                    <Border.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="New session in folder" Click="ContextFolder_AddSession_Click"
                                      Tag="{Binding Folder.Id}" />
                            <MenuItem Header="Rename folder" Click="ContextFolder_Rename_Click"
                                      Tag="{Binding Folder.Id}" />
                            <MenuItem Header="Move folder up" Click="ContextFolder_MoveUp_Click"
                                      Tag="{Binding Folder.Id}" />
                            <MenuItem Header="Move folder down" Click="ContextFolder_MoveDown_Click"
                                      Tag="{Binding Folder.Id}" />
                            <Separator />
                            <MenuItem Header="Expand" Click="ContextFolder_Expand_Click"
                                      Tag="{Binding Folder.Id}" />
                            <MenuItem Header="Collapse" Click="ContextFolder_Collapse_Click"
                                      Tag="{Binding Folder.Id}" />
                            <Separator />
                            <MenuItem Header="Delete folder" Click="ContextFolder_Delete_Click"
                                      Tag="{Binding Folder.Id}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Folder">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                             Value="True">
                                    <Setter Property="Background" Value="{StaticResource SessionFolderSelectedBg}" />
                                    <Setter Property="BorderBrush" Value="#3d4a63" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel HorizontalAlignment="Stretch" MinWidth="0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="AddSessionInFolder_Click" Tag="{Binding Folder.Id}"
                                    ToolTip="New session in folder" Background="Transparent" BorderThickness="0"
                                    Padding="4,3" Cursor="Hand" Foreground="{StaticResource SessionTextSecondary}">
                                <ui:SymbolIcon Symbol="Add24" FontSize="12" />
                            </Button>
                            <Button Click="RenameFolder_Click" Tag="{Binding Folder.Id}"
                                    ToolTip="Rename" Background="Transparent" BorderThickness="0"
                                    Padding="4,3" Cursor="Hand" Foreground="{StaticResource SessionTextSecondary}"
                                    Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            <Button Click="DeleteFolder_Click" Tag="{Binding Folder.Id}"
                                    ToolTip="Delete folder" Background="Transparent" BorderThickness="0"
                                    Padding="4,3" Cursor="Hand" Foreground="{StaticResource SessionTextSecondary}"
                                    Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </StackPanel>
                        <ToggleButton DockPanel.Dock="Left" Width="26" Height="26"
                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                      Background="Transparent" BorderThickness="0"
                                      Focusable="False" Cursor="Hand"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}, Mode=TwoWay}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="#6b7280" HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE76C;" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                         Value="True">
                                                <Setter Property="Text" Value="&#xE70D;" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </ToggleButton>
                        <StackPanel Orientation="Horizontal" MinWidth="0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#22d3ee" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.9" />
                            <TextBlock Text="{Binding Folder.Name}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="#f4f4f5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ═══ Session card ═══ -->
                <Border CornerRadius="8" Padding="10,8" MinHeight="50" HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        ToolTipService.InitialShowDelay="0"
                        ToolTipService.BetweenShowDelay="0"
                        ToolTipService.ShowDuration="60000">
                    <Border.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Open" Click="ContextSession_Open_Click" Tag="{Binding Session.Id}" />
                            <MenuItem Header="Run as administrator" Click="ContextSession_RunAsAdmin_Click"
                                      Tag="{Binding Session.Id}" />
                            <MenuItem Header="Edit" Click="ContextSession_Edit_Click" Tag="{Binding Session.Id}" />
                            <MenuItem Header="Duplicate" Click="ContextSession_Duplicate_Click" Tag="{Binding Session.Id}" />
                            <Separator />
                            <MenuItem Header="Delete" Click="ContextSession_Delete_Click" Tag="{Binding Session.Id}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Session">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Session.ColorTag, Converter={StaticResource HexColor}}"
                                                             Opacity="0.15" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Session.ColorTag, Converter={StaticResource HexColor}}"
                                                             Opacity="0.4" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Kind}" Value="Session" />
                                        <Condition Binding="{Binding Session.HasDescription}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="ToolTip">
                                        <Setter.Value>
                                            <ToolTip Background="#18181b" BorderBrush="#3f3f46"
                                                     BorderThickness="1" Padding="12,10" MaxWidth="320">
                                                <TextBlock Text="{Binding Session.Description}"
                                                           TextWrapping="Wrap" Foreground="#e4e4e7" />
                                            </ToolTip>
                                        </Setter.Value>
                                    </Setter>
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                             Value="True">
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#ffffff" Opacity="0.9" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Session.ColorTag, Converter={StaticResource HexColor}}"
                                                             Opacity="0.28" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Kind}" Value="Session" />
                                        <Condition Binding="{Binding IsMultiSelected}" Value="True" />
                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                   Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="BorderBrush" Value="{StaticResource SessionMultiSelectRing}" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel HorizontalAlignment="Stretch" MinWidth="0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="EditSession_Click" Tag="{Binding Session.Id}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="4,3" Cursor="Hand" Foreground="{StaticResource SessionTextSecondary}"
                                    ToolTip="Edit" Content="&#xE70F;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            <Button Click="DeleteSession_Click" Tag="{Binding Session.Id}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="4,3" Cursor="Hand" Foreground="{StaticResource SessionTextSecondary}"
                                    ToolTip="Delete" Content="&#xE74D;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </StackPanel>
                        <Image DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0"
                               Width="20" Height="20" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding Session, Converter={StaticResource SessionShellIcon}}" />
                        <Grid MinWidth="0" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Session.Name}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#fafafa" TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                            <TextBlock Grid.Row="1" Text="{Binding Session.DisplayCommand}" FontSize="11"
                                       Foreground="{StaticResource SessionTextSecondary}" TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       Margin="0,2,0,0" Opacity="0.92" />
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource SessionPanelBg}" MinWidth="0" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14,12" Background="{StaticResource SessionPanelBg}"
                BorderBrush="{StaticResource SessionDivider}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="Sessions" FontSize="15" FontWeight="SemiBold"
                           Foreground="#fafafa" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Click="ExportSessions_Click"
                            ToolTip="Export sessions (JSON)"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="ArrowUp24" FontSize="14" />
                    </Button>
                    <Button Click="ImportSessions_Click"
                            ToolTip="Import sessions (JSON)"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" />
                    </Button>
                    <Button Click="AddFolderRoot_Click"
                            ToolTip="New folder"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="FolderAdd24" FontSize="14" />
                    </Button>
                    <Button Click="AddSession_Click"
                            ToolTip="New Session (Ctrl+Shift+N)"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Padding="10,8,10,6">
            <Border CornerRadius="8" BorderBrush="#2e323c" BorderThickness="1" Background="#000000" Padding="0">
                <TextBox x:Name="SearchBox"
                         TextChanged="SearchBox_TextChanged"
                         Background="Transparent" Foreground="#f4f4f5"
                         BorderThickness="0"
                         Padding="10,8" FontSize="12"
                         CaretBrush="#e4e4e7" />
            </Border>
        </Border>

        <TreeView x:Name="SessionTree" Grid.Row="2"
                  Background="{StaticResource SessionTreeWell}" BorderThickness="0"
                  Padding="8,6,10,10"
                  HorizontalContentAlignment="Stretch"
                  UseLayoutRounding="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ItemContainerStyle="{StaticResource SessionTreeViewItemStyle}"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="SessionTree_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="SessionTree_PreviewMouseMove"
                  PreviewMouseLeftButtonUp="SessionTree_PreviewMouseLeftButtonUp"
                  DragOver="SessionTree_DragOver"
                  Drop="SessionTree_Drop"
                  SelectedItemChanged="SessionTree_SelectedItemChanged"
                  MouseDoubleClick="SessionTree_MouseDoubleClick">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="New session" Click="ContextTree_NewSession_Click" />
                    <MenuItem Header="New folder" Click="ContextTree_NewFolder_Click" />
                    <Separator />
                    <MenuItem Header="Import from Windows Terminal" Click="ContextTree_ImportWt_Click" />
                    <MenuItem Header="Import from SSH Config" Click="ContextTree_ImportSsh_Click" />
                    <Separator />
                    <MenuItem Header="Export sessions…" Click="ContextTree_ExportSessions_Click" />
                    <MenuItem Header="Import sessions…" Click="ContextTree_ImportSessions_Click" />
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>

        <!-- Snippets -->
        <Border Grid.Row="3" BorderBrush="{StaticResource SessionDivider}" BorderThickness="0,1,0,0"
                Background="{StaticResource SessionPanelBg}">
            <StackPanel>
                <DockPanel Margin="14,10,14,4">
                    <TextBlock Text="Snippets" FontSize="13" FontWeight="SemiBold"
                               Foreground="#fafafa" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Click="ToggleSnippets_Click"
                                ToolTip="Toggle snippets"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,4" Cursor="Hand" Foreground="#888">
                            <TextBlock x:Name="SnippetToggleGlyph" Text="&#xE70D;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button Click="AddSnippet_Click"
                                ToolTip="Add snippet"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,4" Cursor="Hand" Foreground="#888">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                        </Button>
                    </StackPanel>
                </DockPanel>
                <ListBox x:Name="SnippetList" Background="Transparent" BorderThickness="0"
                         Foreground="#ddd" MaxHeight="200"
                         MouseDoubleClick="SnippetList_MouseDoubleClick"
                         Padding="8,0,8,6">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="SnipBd" CornerRadius="6" Padding="10,7"
                                                Background="Transparent">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="&#xE74D;"
                                                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="#555" Click="SnippetDelete_Click"
                                                        Tag="{Binding}" Cursor="Hand"
                                                        Padding="4,2" VerticalAlignment="Center" />
                                                <StackPanel MinWidth="0">
                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                               Foreground="#e4e4e7" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Command}" FontSize="10"
                                                               Foreground="#6b7280" TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SnipBd" Property="Background" Value="#0f1118" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="SnipBd" Property="Background" Value="#161c28" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
