<UserControl
    x:Class="UselessTerminal.Controls.SessionPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:UselessTerminal.Controls"
    xmlns:conv="clr-namespace:UselessTerminal.Converters">

    <UserControl.Resources>
        <conv:HexColorConverter x:Key="HexColor" />
        <conv:SavedSessionShellIconConverter x:Key="SessionShellIcon" />

        <!-- Default TreeViewItem template does not stretch header content; full-width cards need this. -->
        <Style x:Key="SessionTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Padding" Value="0,1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <!-- Column 0 = expand chevron; column 1 = header full width; nested ItemsPresenter is indented for hierarchy. -->
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="0" />
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="Expander" Grid.Row="0" Grid.Column="0"
                                          Width="18" Height="20"
                                          VerticalAlignment="Center"
                                          Background="Transparent" BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <TextBlock x:Name="ExpanderGlyph" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="10" Foreground="#888888" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </ToggleButton>
                            <Border x:Name="Bd" Grid.Row="0" Grid.Column="1"
                                    HorizontalAlignment="Stretch" Background="Transparent">
                                <ContentPresenter x:Name="PART_Header"
                                                  HorizontalAlignment="Stretch"
                                                  ContentSource="Header" />
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1"
                                            Margin="14,0,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpanderGlyph" Property="Text" Value="&#xE70D;" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type local:SessionTreeNode}" ItemsSource="{Binding Children}">
            <Grid HorizontalAlignment="Stretch" MinWidth="0">
                <!-- Folder row: same horizontal padding as session cards; expand/collapse is the TreeView chevron only. -->
                <Border MinHeight="52" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        CornerRadius="4" Padding="8,6" BorderThickness="1" BorderBrush="#2a2a2a">
                    <Border.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="New session in folder" Click="ContextFolder_AddSession_Click"
                                      Tag="{Binding Folder.Id}" />
                            <MenuItem Header="Rename folder" Click="ContextFolder_Rename_Click"
                                      Tag="{Binding Folder.Id}" />
                            <Separator />
                            <MenuItem Header="Expand" Click="ContextFolder_Expand_Click"
                                      Tag="{Binding Folder.Id}" />
                            <MenuItem Header="Collapse" Click="ContextFolder_Collapse_Click"
                                      Tag="{Binding Folder.Id}" />
                            <Separator />
                            <MenuItem Header="Delete folder" Click="ContextFolder_Delete_Click"
                                      Tag="{Binding Folder.Id}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Folder">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                             Value="True">
                                    <Setter Property="Background" Value="#252a32" />
                                    <Setter Property="BorderBrush" Value="#444444" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid HorizontalAlignment="Stretch" MinWidth="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="0" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#00e5ff" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="#aaaaaa" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Text" Value="&#xE76C;" />
                                    <Setter Property="ToolTip" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasItems, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasItems, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                           Value="True" />
                                                <Condition Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                           Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Text" Value="&#xE70D;" />
                                            <Setter Property="ToolTip" Value="Expanded" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="2" Text="{Binding Folder.Name}" FontWeight="SemiBold" FontSize="13"
                                   Foreground="#ffffff" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button Click="AddSessionInFolder_Click" Tag="{Binding Folder.Id}"
                                    ToolTip="New session in folder" Background="Transparent" BorderThickness="0"
                                    Padding="4,2" Cursor="Hand" Foreground="#888888">
                                <ui:SymbolIcon Symbol="Add24" FontSize="12" />
                            </Button>
                            <Button Click="RenameFolder_Click" Tag="{Binding Folder.Id}"
                                    ToolTip="Rename" Background="Transparent" BorderThickness="0"
                                    Padding="4,2" Cursor="Hand" Foreground="#888888"
                                    Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            <Button Click="DeleteFolder_Click" Tag="{Binding Folder.Id}"
                                    ToolTip="Delete folder" Background="Transparent" BorderThickness="0"
                                    Padding="4,2" Cursor="Hand" Foreground="#888888"
                                    Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Session row -->
                <Border CornerRadius="4" Padding="8,6" MinHeight="52" HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        ToolTipService.InitialShowDelay="0"
                        ToolTipService.BetweenShowDelay="0"
                        ToolTipService.ShowDuration="60000">
                    <Border.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Open" Click="ContextSession_Open_Click" Tag="{Binding Session.Id}" />
                            <MenuItem Header="Run as administrator" Click="ContextSession_RunAsAdmin_Click"
                                      Tag="{Binding Session.Id}" />
                            <MenuItem Header="Edit" Click="ContextSession_Edit_Click" Tag="{Binding Session.Id}" />
                            <MenuItem Header="Duplicate" Click="ContextSession_Duplicate_Click" Tag="{Binding Session.Id}" />
                            <Separator />
                            <MenuItem Header="Delete" Click="ContextSession_Delete_Click" Tag="{Binding Session.Id}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Session">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Session.ColorTag, Converter={StaticResource HexColor}}"
                                                             Opacity="0.15" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Session.ColorTag, Converter={StaticResource HexColor}}"
                                                             Opacity="0.4" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Kind}" Value="Session" />
                                        <Condition Binding="{Binding Session.HasDescription}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="ToolTip">
                                        <Setter.Value>
                                            <ToolTip Background="#1a1a1a" BorderBrush="#444444"
                                                     BorderThickness="1" Padding="10,8" MaxWidth="320">
                                                <TextBlock Text="{Binding Session.Description}"
                                                           TextWrapping="Wrap" Foreground="#ffffff" />
                                            </ToolTip>
                                        </Setter.Value>
                                    </Setter>
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                             Value="True">
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#ffffff" Opacity="0.9" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Session.ColorTag, Converter={StaticResource HexColor}}"
                                                             Opacity="0.28" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid HorizontalAlignment="Stretch" MinWidth="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="0" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                               Width="18" Height="18" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding Session, Converter={StaticResource SessionShellIcon}}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                            <TextBlock Text="{Binding Session.Name}" FontSize="13"
                                       Foreground="#ffffff" TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                            <TextBlock Text="{Binding Session.DisplayCommand}" FontSize="10"
                                       Foreground="#888888" TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="EditSession_Click" Tag="{Binding Session.Id}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="4,2" Cursor="Hand" Foreground="#888888"
                                    ToolTip="Edit" Content="&#xE70F;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            <Button Click="DeleteSession_Click" Tag="{Binding Session.Id}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="4,2" Cursor="Hand" Foreground="#888888"
                                    ToolTip="Delete" Content="&#xE74D;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Background="#000000">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12,10" Background="#000000"
                BorderBrush="#333333" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="Sessions" FontSize="14" FontWeight="Bold"
                           Foreground="#ffffff" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Click="ExportSessions_Click"
                            ToolTip="Export sessions (JSON)"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="ArrowUp24" FontSize="14" />
                    </Button>
                    <Button Click="ImportSessions_Click"
                            ToolTip="Import sessions (JSON)"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" />
                    </Button>
                    <Button Click="AddFolderRoot_Click"
                            ToolTip="New folder"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="FolderAdd24" FontSize="14" />
                    </Button>
                    <Button Click="AddSession_Click"
                            ToolTip="New Session (Ctrl+Shift+N)"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" Foreground="#ffffff">
                        <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Padding="8,6">
            <TextBox x:Name="SearchBox"
                     TextChanged="SearchBox_TextChanged"
                     Background="#000000" Foreground="#ffffff"
                     BorderBrush="#555555" BorderThickness="1"
                     Padding="8,5" FontSize="12" />
        </Border>

        <TreeView x:Name="SessionTree" Grid.Row="2"
                  Background="Transparent" BorderThickness="0"
                  Padding="0,2,4,4"
                  HorizontalContentAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ItemContainerStyle="{StaticResource SessionTreeViewItemStyle}"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="SessionTree_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="SessionTree_PreviewMouseMove"
                  PreviewMouseLeftButtonUp="SessionTree_PreviewMouseLeftButtonUp"
                  DragOver="SessionTree_DragOver"
                  Drop="SessionTree_Drop"
                  MouseDoubleClick="SessionTree_MouseDoubleClick">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="New session" Click="ContextTree_NewSession_Click" />
                    <MenuItem Header="New folder" Click="ContextTree_NewFolder_Click" />
                    <Separator />
                    <MenuItem Header="Import from Windows Terminal" Click="ContextTree_ImportWt_Click" />
                    <Separator />
                    <MenuItem Header="Export sessions…" Click="ContextTree_ExportSessions_Click" />
                    <MenuItem Header="Import sessions…" Click="ContextTree_ImportSessions_Click" />
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>

</UserControl>
