<Window
    x:Class="UselessTerminal.Controls.SessionEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Session"
    Width="460" SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#000000"
    Foreground="#ffffff">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Name" FontSize="12" Foreground="#888888" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" FontSize="13" Padding="8,6"
                     Background="#000000" Foreground="#ffffff"
                     BorderBrush="#555555" BorderThickness="1" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Shell Path" FontSize="12" Foreground="#888888" Margin="0,0,0,4" />
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseShell_Click"
                        Margin="6,0,0,0" Padding="10,6"
                        Background="#000000" Foreground="#ffffff"
                        BorderBrush="#555555" BorderThickness="1" />
                <TextBox x:Name="ShellPathBox" FontSize="13" Padding="8,6"
                         Background="#000000" Foreground="#ffffff"
                         BorderBrush="#555555" BorderThickness="1" />
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Arguments" FontSize="12" Foreground="#888888" Margin="0,0,0,4" />
            <TextBox x:Name="ArgumentsBox" FontSize="13" Padding="8,6"
                     Background="#000000" Foreground="#ffffff"
                     BorderBrush="#555555" BorderThickness="1" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Working Directory" FontSize="12" Foreground="#888888" Margin="0,0,0,4" />
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseDir_Click"
                        Margin="6,0,0,0" Padding="10,6"
                        Background="#000000" Foreground="#ffffff"
                        BorderBrush="#555555" BorderThickness="1" />
                <TextBox x:Name="WorkDirBox" FontSize="13" Padding="8,6"
                         Background="#000000" Foreground="#ffffff"
                         BorderBrush="#555555" BorderThickness="1" />
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Starting Command" FontSize="12" Foreground="#888888" Margin="0,0,0,4" />
            <TextBox x:Name="StartingCommandBox" FontSize="13" Padding="8,6"
                     Background="#000000" Foreground="#ffffff"
                     BorderBrush="#555555" BorderThickness="1" />
            <TextBlock Text="Runs after shell starts (e.g. ssh user@host, cd /project)" 
                       FontSize="10" Foreground="#555555" Margin="0,3,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Text="Color Tag" FontSize="12" Foreground="#888888" Margin="0,0,0,4" />
            <WrapPanel>
                <RadioButton x:Name="ColorBlue" Tag="#00ff44" Margin="0,0,6,0"
                             Click="Color_Click" IsChecked="True">
                    <Ellipse Width="20" Height="20" Fill="#00ff44" />
                </RadioButton>
                <RadioButton Tag="#ff003c" Margin="0,0,6,0" Click="Color_Click">
                    <Ellipse Width="20" Height="20" Fill="#ff003c" />
                </RadioButton>
                <RadioButton Tag="#ffff00" Margin="0,0,6,0" Click="Color_Click">
                    <Ellipse Width="20" Height="20" Fill="#ffff00" />
                </RadioButton>
                <RadioButton Tag="#00e5ff" Margin="0,0,6,0" Click="Color_Click">
                    <Ellipse Width="20" Height="20" Fill="#00e5ff" />
                </RadioButton>
                <RadioButton Tag="#ff00ff" Margin="0,0,6,0" Click="Color_Click">
                    <Ellipse Width="20" Height="20" Fill="#ff00ff" />
                </RadioButton>
                <RadioButton Tag="#ff8800" Margin="0,0,6,0" Click="Color_Click">
                    <Ellipse Width="20" Height="20" Fill="#ff8800" />
                </RadioButton>
            </WrapPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,8"
                    Margin="0,0,8,0" Background="#000000" Foreground="#ffffff"
                    BorderBrush="#555555" BorderThickness="1" />
            <Button Content="Save" Click="Save_Click" Padding="16,8"
                    Background="#ffffff" Foreground="#000000"
                    BorderThickness="0" FontWeight="Bold" />
        </StackPanel>
    </Grid>

</Window>
